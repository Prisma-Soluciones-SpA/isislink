# Server
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8100

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=astrallink
DB_USER=postgres
DB_PASSWORD=your_password

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Transbank WebPay Plus
# Modo integración (testing): dejar vacíos para usar credenciales de prueba automáticas
# Modo producción: completar con credenciales reales de Transbank
TBK_COMMERCE_CODE=
TBK_API_KEY=
TBK_ENVIRONMENT=integration

# URLs para callbacks de Transbank
TBK_RETURN_URL=http://localhost:3000/api/subscriptions/confirm

# Uploads
UPLOAD_DIR=uploads/profiles
MAX_FILE_SIZE=5242880
